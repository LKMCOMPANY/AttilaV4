# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Attila V4)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Access (box tunnels)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Gorgone integration (separate Supabase project)
GORGONE_SUPABASE_URL=
GORGONE_SUPABASE_SERVICE_ROLE_KEY=
# Shared secret used to authenticate webhooks from Gorgone -> Attila.
# >=32 chars, base64url. Mirrored to Gorgone's `integration_config` via
# the admin "Push webhook config" action.
GORGONE_WEBHOOK_SECRET=
# Sweep cadence in ms (safety net behind the webhook). Default 60000.
GORGONE_SWEEP_INTERVAL_MS=60000

# Aleria LLM (OpenAI-compatible)
ALERIA_API_KEY=
ALERIA_BASE_URL=https://inference.aleria.com/v1

# Pipeline cron protection
CRON_SECRET=
